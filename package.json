{
  "name": "aurea-modern-fashion-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:all",
    "prelaunch": "node scripts/ensure-dependencies.js",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "build": "npm exec --yes --package=node@24.15.0 -- node frontend/node_modules/@angular/cli/bin/ng.js build",
    "start": "npm --prefix backend start",
    "launch": "npm run build && npm start"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
